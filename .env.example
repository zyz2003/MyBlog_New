# ===========================================
# 博客系统环境变量配置模板
# ===========================================
# 使用方法：复制此文件为 .env 并填入实际值

# -------------------------------------------
# 数据库配置 (MySQL) - 必需
# -------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=my_blog

# -------------------------------------------
# JWT 密钥 - 必需，至少 32 个字符
# 建议使用随机字符串生成工具生成
# 例如：openssl rand -base64 32
# -------------------------------------------
JWT_SECRET=your-32-character-or-longer-secret-key-here

# -------------------------------------------
# 管理员密码 - 可选
# 首次启动时设置，用于创建初始管理员账户
# -------------------------------------------
# ADMIN_PASSWORD=your_admin_password

# -------------------------------------------
# 站点配置 - 可选
# -------------------------------------------
SITE_NAME=My Blog
SITE_DESCRIPTION=个人博客系统

# -------------------------------------------
# 服务器配置 - 可选
# -------------------------------------------
NUXT_HOST=0.0.0.0
NUXT_PORT=3000
