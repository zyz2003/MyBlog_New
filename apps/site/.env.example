# ========================
# Environment Variables
# ========================
# Copy this file to .env and fill in values
# NEVER commit .env to git (already in .gitignore)

# --- Database ---
# Path to SQLite database file (relative to project root)
DATABASE_URL=./database/blog.sqlite

# --- Authentication ---
# JWT secret for token signing (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-string

# --- Server ---
# Nuxt host and port (optional, defaults to localhost:3000)
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# --- App ---
# Site URL (used for SEO, RSS, sitemap)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=My Blog

# --- Storage ---
# Storage type: local | oss | cos | s3
STORAGE_TYPE=local
# Local storage path (relative to project root)
STORAGE_BASE_PATH=./uploads
# Base URL for serving uploaded files
STORAGE_BASE_URL=/uploads
