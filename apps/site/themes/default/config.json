{
  "name": "default",
  "version": "1.0.0",
  "author": "Blog Team",
  "description": "默认主题，简洁清爽的博客风格",
  "colors": {
    "primary": "#3B82F6",
    "secondary": "#64748B",
    "accent": "#8B5CF6",
