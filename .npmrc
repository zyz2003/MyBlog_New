# pnpm workspace configuration
# Optimized for cleaner node_modules structure

# Use shared lockfile across workspace
shared-workspace-lockfile=true

# Don't create symlinked node_modules in each package
# Dependencies are hoisted to root, reducing visual clutter
link-workspace-packages=false

# Inject workspace packages as dependencies
inject-workspace-packages=true

# Enable hoisting for better IDE compatibility
shamefully-hoist=true
